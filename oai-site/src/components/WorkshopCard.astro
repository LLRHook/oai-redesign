---
interface Props {
  slug: string;
  title: string;
  speakerName: string;
  description: string;
  duration: string;
  date: string;
}

const { slug, title, speakerName, description, duration, date } = Astro.props;
---

<a href={`/workshops/${slug}`} class="group block">
  <div class="relative rounded-xl bg-surface border border-surface-border p-6 lg:p-8 transition-all duration-300 hover:border-primary/30 hover:-translate-y-1 hover:shadow-[0_8px_40px_rgba(255,107,53,0.08)] h-full flex flex-col">
    <!-- Duration badge -->
    <div class="flex items-center gap-3 mb-4">
      <span class="inline-flex items-center px-2.5 py-1 rounded-md text-[11px] font-display font-600 uppercase tracking-wider bg-secondary/10 text-secondary border border-secondary/20">
        {duration}
      </span>
      <span class="text-xs text-text-tertiary font-body">{date}</span>
    </div>

    <!-- Title -->
    <h3 class="font-display text-xl font-600 text-text-primary leading-tight mb-3 group-hover:text-primary transition-colors duration-300">
      {title}
    </h3>

    <!-- Speaker -->
    <p class="text-sm text-primary font-display font-500 mb-4">
      {speakerName}
    </p>

    <!-- Description -->
    <p class="text-sm text-text-secondary font-body leading-relaxed line-clamp-3 flex-1">
      {description}
    </p>

    <!-- Arrow -->
    <div class="mt-6 flex items-center gap-2 text-sm font-display font-600 text-text-tertiary group-hover:text-primary transition-all duration-300">
      <span>View Details</span>
      <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </div>
  </div>
</a>
