---
interface Props {
  title: string;
  subtitle?: string;
  badge?: string;
  showStats?: boolean;
}

const { title, subtitle, badge, showStats = false } = Astro.props;
---

<section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden">
  <!-- Animated Gradient Mesh Background -->
  <div class="hero-gradient-mesh absolute inset-0 pointer-events-none"></div>

  <!-- Background Geometric Accents -->
  <div class="absolute inset-0 pointer-events-none">
    <!-- Top-right angular shape -->
    <div class="absolute top-20 right-0 w-[400px] h-[400px] opacity-[0.06]"
      style="background: linear-gradient(135deg, #FF6B35 0%, transparent 60%); clip-path: polygon(30% 0%, 100% 0%, 100% 70%, 70% 100%);"
    ></div>
    <!-- Bottom-left angular shape -->
    <div class="absolute bottom-0 left-0 w-[350px] h-[350px] opacity-[0.04]"
      style="background: linear-gradient(45deg, #00D4AA 0%, transparent 60%); clip-path: polygon(0% 30%, 70% 0%, 100% 70%, 30% 100%, 0% 100%);"
    ></div>
    <!-- Floating dot grid -->
    <div class="absolute top-1/4 left-1/4 w-2 h-2 rounded-full bg-primary/20" style="animation: float 6s ease-in-out infinite;"></div>
    <div class="absolute top-1/3 right-1/3 w-1.5 h-1.5 rounded-full bg-secondary/20" style="animation: float 8s ease-in-out infinite 1s;"></div>
    <div class="absolute bottom-1/3 left-1/2 w-2.5 h-2.5 rounded-full bg-primary/15" style="animation: float 7s ease-in-out infinite 0.5s;"></div>
    <!-- Diagonal line accent -->
    <div class="absolute top-0 left-1/2 w-px h-40 bg-gradient-to-b from-transparent via-primary/10 to-transparent rotate-[20deg]"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 lg:px-8 text-center pt-32 pb-20">
    {badge && (
      <div class="mb-6" style="animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;">
        <span class="inline-flex items-center px-4 py-1.5 rounded-md text-xs font-display font-600 uppercase tracking-widest border bg-primary/10 text-primary border-primary/20">
          {badge}
        </span>
      </div>
    )}

    <h1
      class="font-display text-5xl sm:text-6xl md:text-7xl lg:text-[5rem] font-700 text-text-primary tracking-tight leading-[1.05]"
      style="animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;"
    >
      <slot name="title">
        <Fragment set:html={title} />
      </slot>
    </h1>

    {subtitle && (
      <p
        class="mt-6 text-lg md:text-xl text-text-secondary font-body max-w-2xl mx-auto leading-relaxed"
        style="animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;"
      >
        {subtitle}
      </p>
    )}

    <slot />

    <!-- Countdown Timer -->
    <div
      class="mt-10 flex items-center justify-center gap-3 sm:gap-4"
      style="animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.35s both;"
      id="countdown-container"
    >
      <div class="countdown-box">
        <span id="countdown-days" class="countdown-number">--</span>
        <span class="countdown-label">Days</span>
      </div>
      <span class="text-text-tertiary font-display text-2xl font-300 select-none">:</span>
      <div class="countdown-box">
        <span id="countdown-hours" class="countdown-number">--</span>
        <span class="countdown-label">Hours</span>
      </div>
      <span class="text-text-tertiary font-display text-2xl font-300 select-none">:</span>
      <div class="countdown-box">
        <span id="countdown-minutes" class="countdown-number">--</span>
        <span class="countdown-label">Mins</span>
      </div>
      <span class="text-text-tertiary font-display text-2xl font-300 select-none">:</span>
      <div class="countdown-box">
        <span id="countdown-seconds" class="countdown-number">--</span>
        <span class="countdown-label">Secs</span>
      </div>
    </div>

    {showStats && (
      <div
        class="mt-16 grid grid-cols-3 gap-8 max-w-lg mx-auto"
        style="animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both;"
      >
        <div class="text-center">
          <div class="font-display text-3xl md:text-4xl font-700 text-primary">70+</div>
          <div class="mt-1 text-xs text-text-tertiary font-display font-500 uppercase tracking-wider">Speakers</div>
        </div>
        <div class="text-center">
          <div class="font-display text-3xl md:text-4xl font-700 text-secondary">11</div>
          <div class="mt-1 text-xs text-text-tertiary font-display font-500 uppercase tracking-wider">Workshops</div>
        </div>
        <div class="text-center">
          <div class="font-display text-3xl md:text-4xl font-700 text-text-primary">2</div>
          <div class="mt-1 text-xs text-text-tertiary font-display font-500 uppercase tracking-wider">Days</div>
        </div>
      </div>
    )}
  </div>

  <!-- Bottom gradient fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-bg to-transparent"></div>
</section>

<style>
  .hero-gradient-mesh {
    background:
      radial-gradient(ellipse at 20% 50%, rgba(255, 107, 53, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(0, 212, 170, 0.10) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 80%, rgba(255, 107, 53, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 80%, rgba(0, 212, 170, 0.06) 0%, transparent 50%);
    background-size: 400% 400%;
    animation: gradient-shift 20s ease infinite;
  }

  @keyframes gradient-shift {
    0% { background-position: 0% 50%; }
    25% { background-position: 50% 0%; }
    50% { background-position: 100% 50%; }
    75% { background-position: 50% 100%; }
    100% { background-position: 0% 50%; }
  }

  .countdown-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 72px;
    padding: 12px 16px;
    border-radius: 10px;
    background: rgba(26, 26, 30, 0.7);
    border: 1px solid rgba(42, 42, 46, 0.6);
    backdrop-filter: blur(8px);
  }

  .countdown-number {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 32px;
    font-weight: 700;
    line-height: 1;
    color: var(--color-text-primary, #FAFAFA);
  }

  .countdown-label {
    font-family: var(--font-body, 'Plus Jakarta Sans', sans-serif);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-tertiary, #6B6B74);
    margin-top: 4px;
  }

  @media (max-width: 480px) {
    .countdown-box {
      min-width: 56px;
      padding: 8px 10px;
    }
    .countdown-number {
      font-size: 24px;
    }
    .countdown-label {
      font-size: 10px;
    }
  }
</style>

<script>
  function updateCountdown() {
    const target = new Date('2026-03-30T09:00:00-04:00').getTime();
    const now = Date.now();
    const diff = target - now;

    const days = document.getElementById('countdown-days');
    const hours = document.getElementById('countdown-hours');
    const minutes = document.getElementById('countdown-minutes');
    const seconds = document.getElementById('countdown-seconds');

    if (!days || !hours || !minutes || !seconds) return;

    if (diff <= 0) {
      days.textContent = '0';
      hours.textContent = '0';
      minutes.textContent = '0';
      seconds.textContent = '0';
      return;
    }

    const d = Math.floor(diff / (1000 * 60 * 60 * 24));
    const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const s = Math.floor((diff % (1000 * 60)) / 1000);

    days.textContent = String(d);
    hours.textContent = String(h).padStart(2, '0');
    minutes.textContent = String(m).padStart(2, '0');
    seconds.textContent = String(s).padStart(2, '0');
  }

  updateCountdown();
  setInterval(updateCountdown, 1000);
</script>
