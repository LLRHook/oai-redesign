---
import { footerContent } from '../data/navigation';
---

<footer class="bg-surface border-t border-surface-border">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 lg:gap-8">
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block">
          <span class="font-display text-3xl font-800 tracking-tight text-primary">OAI</span>
        </a>
        <p class="mt-4 text-text-secondary text-sm leading-relaxed font-body">
          A practitioner-focused AI conference in Atlanta. Affordable, hands-on, no fluff.
        </p>
        <div class="mt-6 flex gap-4">
          {footerContent.socials.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.text}
              class="w-10 h-10 rounded-lg bg-surface-elevated border border-surface-border flex items-center justify-center text-text-tertiary hover:text-primary hover:border-primary/30 transition-all duration-300"
            >
              {social.text === "YouTube" ? (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              ) : social.text === "LinkedIn" ? (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              ) : (
                <span class="text-xs font-display font-600">{social.text}</span>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Link Columns -->
      {footerContent.columns.map((col) => (
        <div>
          <h4 class="font-display text-sm font-600 text-text-primary uppercase tracking-wider mb-5">
            {col.title}
          </h4>
          <ul class="space-y-3">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-text-secondary hover:text-primary transition-colors duration-200 font-body"
                >
                  {link.text}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-surface-border">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-text-tertiary text-xs font-body">
        &copy; {new Date().getFullYear()} {footerContent.copyright}. All rights reserved.
      </p>
      <div class="flex items-center gap-6 text-xs text-text-tertiary font-body">
        <span>{footerContent.address}</span>
        <a href={`tel:${footerContent.phone}`} class="hover:text-primary transition-colors">{footerContent.phone}</a>
      </div>
    </div>
  </div>
</footer>
