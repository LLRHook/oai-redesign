---
import { getAvatarColor, getInitials } from '../data/speakers';

interface Props {
  quote: string;
  name: string;
  role: string;
}

const { quote, name, role } = Astro.props;
const bgColor = getAvatarColor(name);
const initials = getInitials(name);
---

<div class="group relative rounded-xl bg-surface border border-surface-border p-6 lg:p-8 transition-all duration-300 hover:border-primary/20 hover:-translate-y-1">
  <!-- Quote mark -->
  <div class="absolute top-4 right-6 text-6xl font-display font-800 text-surface-border/50 leading-none select-none">
    "
  </div>

  <!-- Quote -->
  <blockquote class="relative z-10 text-text-secondary font-body text-base leading-relaxed mb-6 italic">
    "{quote}"
  </blockquote>

  <!-- Author -->
  <div class="flex items-center gap-3">
    <div
      class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
      style={`background: ${bgColor}`}
    >
      <span class="text-sm font-display font-700 text-white/90">{initials}</span>
    </div>
    <div>
      <p class="font-display text-sm font-600 text-text-primary">{name}</p>
      <p class="text-xs text-text-tertiary font-body">{role}</p>
    </div>
  </div>
</div>
