---
interface Props {
  name: string;
  price: string;
  originalPrice?: string;
  description: string;
  features: string[];
  featured?: boolean;
  ctaText: string;
}

const { name, price, originalPrice, description, features, featured = false, ctaText } = Astro.props;
---

<div class={`relative rounded-xl p-px ${featured ? 'gradient-border-glow' : ''}`}>
  <div class={`relative rounded-xl p-6 lg:p-8 h-full flex flex-col ${featured ? 'bg-surface-elevated' : 'bg-surface border border-surface-border'}`}>
    {featured && (
      <span class="absolute -top-3 left-1/2 -translate-x-1/2 inline-flex items-center px-4 py-1 rounded-md text-xs font-display font-700 uppercase tracking-wider bg-primary text-bg">
        Most Popular
      </span>
    )}

    <!-- Name -->
    <h3 class={`font-display text-2xl font-600 mb-2 ${featured ? 'text-primary' : 'text-text-primary'}`}>
      {name}
    </h3>

    <!-- Price -->
    <div class="flex items-baseline gap-2 mb-4">
      <span class="font-display text-4xl font-700 text-text-primary">{price}</span>
      {originalPrice && (
        <span class="text-lg text-text-tertiary line-through font-body">{originalPrice}</span>
      )}
    </div>

    <!-- Description -->
    <p class="text-sm text-text-secondary font-body leading-relaxed mb-6">
      {description}
    </p>

    <!-- Features -->
    <ul class="space-y-3 mb-8 flex-1">
      {features.map((feature) => (
        <li class="flex items-start gap-3 text-sm text-text-secondary font-body">
          <svg class={`w-5 h-5 flex-shrink-0 mt-0.5 ${featured ? 'text-primary' : 'text-secondary'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span>{feature}</span>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <a
      href="/contact"
      class={`w-full inline-flex items-center justify-center px-6 py-3.5 rounded-lg font-display font-600 text-sm transition-all duration-300 ${
        featured
          ? 'bg-primary hover:bg-primary-hover text-bg hover:shadow-[0_0_24px_rgba(255,107,53,0.35)]'
          : 'border-2 border-surface-border text-text-primary hover:border-primary hover:text-primary'
      }`}
    >
      {ctaText}
    </a>
  </div>
</div>
