---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="404 - Page Not Found | Optimized AI Conference 2026" description="The page you're looking for doesn't exist.">

  <section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden">
    <!-- Background Geometric Accents -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-20 right-0 w-[300px] h-[300px] opacity-[0.04]"
        style="background: linear-gradient(135deg, #FF6B35, transparent 60%); clip-path: polygon(30% 0%, 100% 0%, 100% 70%, 70% 100%);"
      ></div>
      <div class="absolute bottom-0 left-0 w-[250px] h-[250px] opacity-[0.03]"
        style="background: linear-gradient(45deg, #00D4AA, transparent 60%); clip-path: polygon(0% 30%, 70% 0%, 100% 70%, 30% 100%, 0% 100%);"
      ></div>
    </div>

    <div class="relative z-10 text-center px-6">
      <h1
        class="font-display text-[8rem] sm:text-[10rem] md:text-[12rem] font-800 text-primary leading-none tracking-tight"
        style="animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;"
      >
        404
      </h1>
      <p
        class="font-display text-2xl md:text-3xl font-600 text-text-primary mt-2 mb-4"
        style="animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;"
      >
        Page not found
      </p>
      <p
        class="text-text-secondary font-body max-w-md mx-auto mb-10"
        style="animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;"
      >
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div style="animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;">
        <Button href="/" variant="primary" size="lg">
          Back to Home
        </Button>
      </div>
    </div>
  </section>

</BaseLayout>
