---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormField from '../components/FormField.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Contact Us | Optimized AI Conference 2026" description="Contact the Optimized AI Conference team for help with registration, speakers, schedules, sponsorships, or event info.">

  <!-- Hero -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute top-20 right-0 w-[300px] h-[300px] opacity-[0.04]"
      style="background: linear-gradient(135deg, #FF6B35, transparent 60%); clip-path: polygon(30% 0%, 100% 0%, 100% 70%, 70% 100%);"
    ></div>

    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <span
        class="inline-flex items-center px-4 py-1.5 rounded-md text-xs font-display font-600 uppercase tracking-widest border bg-primary/10 text-primary border-primary/20 mb-6"
        style="animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;"
      >
        Get in Touch
      </span>
      <h1
        class="font-display text-5xl md:text-6xl font-700 text-text-primary tracking-tight mb-6"
        style="animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;"
      >
        Contact Us
      </h1>
      <p
        class="text-lg text-text-secondary font-body max-w-xl mx-auto"
        style="animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;"
      >
        Building and deploying analytics, machine-learning and gen AI applications to production is no easy task. Shorten your path to production.
      </p>
    </div>
  </section>

  <!-- Form + Info -->
  <section class="py-20 bg-surface">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Info Column -->
        <div class="lg:col-span-2 animate-on-scroll">
          <h2 class="font-display text-2xl font-600 text-text-primary mb-4">Have Questions?</h2>
          <p class="text-text-secondary font-body leading-relaxed mb-8">
            Thanks for looking into the conference. You can use this form to get more information about speaking at the conference, sponsorships, ticket prices, workshops, or any other questions you may have. Looking forward to hosting you in March 2026.
          </p>

          <!-- Contact Info -->
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="font-display text-sm font-600 text-text-primary">Email</p>
                <p class="text-sm text-text-secondary font-body">team@oaiconference.com</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-secondary/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="font-display text-sm font-600 text-text-primary">Phone</p>
                <a href="tel:+16414556100" class="text-sm text-text-secondary font-body hover:text-primary transition-colors">+1 (641) 455-6100</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="font-display text-sm font-600 text-text-primary">Address</p>
                <p class="text-sm text-text-secondary font-body">23 Lilac Dr, Warren, NJ 07059</p>
              </div>
            </div>
          </div>

          <!-- Social Media -->
          <div class="mt-10">
            <h3 class="font-display text-sm font-600 text-text-primary uppercase tracking-wider mb-4">Social Media</h3>
            <div class="flex gap-4">
              <a href="https://www.youtube.com/@oaiconference" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg bg-surface-elevated border border-surface-border flex items-center justify-center text-text-tertiary hover:text-primary hover:border-primary/30 transition-all duration-300">
                <span class="text-xs font-display font-600">YT</span>
              </a>
              <a href="https://www.linkedin.com/company/oaico" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg bg-surface-elevated border border-surface-border flex items-center justify-center text-text-tertiary hover:text-primary hover:border-primary/30 transition-all duration-300">
                <span class="text-xs font-display font-600">LI</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Form Column -->
        <div class="lg:col-span-3 animate-on-scroll">
          <div class="rounded-xl bg-surface-elevated border border-surface-border p-8 lg:p-10">
            <h2 class="font-display text-2xl font-600 text-text-primary mb-8">Get In Touch</h2>
            <form class="space-y-6" action="#" method="POST">
              <FormField label="Name" type="text" name="name" required={true} />
              <FormField label="Email" type="email" name="email" required={true} />
              <FormField label="Subject" type="text" name="subject" required={true} />
              <FormField label="Message" type="textarea" name="message" required={true} />
              <Button variant="primary" size="lg">
                Submit
              </Button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
