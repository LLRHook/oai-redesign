---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import SectionHeader from '../components/SectionHeader.astro';
import TicketCard from '../components/TicketCard.astro';
import Badge from '../components/Badge.astro';
import Button from '../components/Button.astro';
import { tickets } from '../data/tickets';
import { inPersonSchedule } from '../data/schedule';
---

<BaseLayout title="Event Details | Optimized AI Conference 2026" description="Date, venue, tickets, and everything you need to know about the Optimized AI Conference 2026 in Atlanta.">

  <!-- Hero -->
  <HeroSection
    title="Event Details"
    subtitle="Everything you need to know about the Optimized AI Conference 2026 -- dates, venue, tickets, and logistics."
    badge="March 30-31, 2026"
  />

  <!-- Date & Venue -->
  <section class="py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <SectionHeader
        title="Date & Venue"
        subtitle="Two days of talks, workshops, and networking at one of Atlanta's premier event spaces."
        badge="Location"
      />

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-4xl mx-auto animate-on-scroll">
        <!-- Date Info -->
        <div class="rounded-xl bg-surface-elevated border border-surface-border p-8">
          <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-600 text-text-primary mb-4">Conference Dates</h3>
          <div class="space-y-4">
            <div class="flex items-start gap-4">
              <Badge variant="primary">Day 1</Badge>
              <div>
                <p class="font-display text-sm font-600 text-text-primary">{inPersonSchedule.day1.date}</p>
                <p class="text-sm text-text-secondary font-body">{inPersonSchedule.day1.label}</p>
                <p class="text-xs text-text-tertiary font-body mt-1">{inPersonSchedule.day1.description}</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <Badge variant="secondary">Day 2</Badge>
              <div>
                <p class="font-display text-sm font-600 text-text-primary">{inPersonSchedule.day2.date}</p>
                <p class="text-sm text-text-secondary font-body">{inPersonSchedule.day2.label}</p>
                <p class="text-xs text-text-tertiary font-body mt-1">{inPersonSchedule.day2.description}</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Venue Info -->
        <div class="rounded-xl bg-surface-elevated border border-surface-border p-8">
          <div class="w-12 h-12 rounded-lg bg-secondary/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-600 text-text-primary mb-4">Venue</h3>
          <div class="space-y-3 text-sm text-text-secondary font-body">
            <p><strong class="text-text-primary font-display font-500">Cobb Galleria Center</strong></p>
            <p>Two Galleria Parkway SE<br />Atlanta, GA 30339</p>
            <p class="text-xs text-text-tertiary">Located just off I-285, the Cobb Galleria Center is easily accessible with ample parking and nearby hotel options.</p>
          </div>
          <div class="mt-6 space-y-3">
            <div class="flex items-center gap-3 text-sm text-text-secondary font-body">
              <svg class="w-4 h-4 text-secondary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Free on-site parking</span>
            </div>
            <div class="flex items-center gap-3 text-sm text-text-secondary font-body">
              <svg class="w-4 h-4 text-secondary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Hotels available nearby</span>
            </div>
            <div class="flex items-center gap-3 text-sm text-text-secondary font-body">
              <svg class="w-4 h-4 text-secondary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>20 minutes from ATL airport</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tickets -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <SectionHeader
        title="Ticket Tiers"
        subtitle="Affordable pricing for everyone -- from students to executives."
        badge="Register Now"
      />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 animate-on-scroll">
        {tickets.map((t) => (
          <TicketCard
            name={t.name}
            price={t.price}
            originalPrice={t.originalPrice}
            description={t.description}
            features={t.features}
            featured={t.featured}
            ctaText={t.ctaText}
          />
        ))}
      </div>

      <div class="mt-8 text-center">
        <p class="text-sm text-text-tertiary font-body">
          Teams of 3+ get 30% off with code <span class="text-primary font-600 font-display">GROUP30</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Free & Discount Options -->
  <section class="py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <SectionHeader
        title="Free & Discounted Options"
        subtitle="We keep the conference affordable so everyone can participate."
        badge="Save Money"
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 animate-on-scroll">
        <div class="rounded-xl bg-surface-elevated border border-surface-border p-6 transition-all duration-300 hover:border-primary/20 hover:-translate-y-1">
          <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-600 text-text-primary mb-2">Decision Makers - FREE</h3>
          <p class="text-sm text-text-secondary font-body leading-relaxed">
            Senior managers and above are eligible to apply for a complimentary ticket -- email team@oaiconference.com with your LinkedIn profile.
          </p>
        </div>

        <div class="rounded-xl bg-surface-elevated border border-surface-border p-6 transition-all duration-300 hover:border-secondary/20 hover:-translate-y-1">
          <div class="w-12 h-12 rounded-lg bg-secondary/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-600 text-text-primary mb-2">Repost Discount - 25%</h3>
          <p class="text-sm text-text-secondary font-body leading-relaxed">
            Get 25% off when you repost a conference update on LinkedIn or X. Email a screenshot to get your discount code.
          </p>
        </div>

        <div class="rounded-xl bg-surface-elevated border border-surface-border p-6 transition-all duration-300 hover:border-primary/20 hover:-translate-y-1">
          <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-600 text-text-primary mb-2">Volunteer - FREE</h3>
          <p class="text-sm text-text-secondary font-body leading-relaxed">
            Volunteers get free access to talks after their shift. Register with code VOL-2026 -- limited tickets available.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center animate-on-scroll">
      <h2 class="font-display text-3xl md:text-4xl font-600 text-text-primary mb-4">
        Questions about the event?
      </h2>
      <p class="text-text-secondary font-body mb-8">
        Reach out to our team for help with registration, group discounts, sponsorships, or any other questions.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/contact" variant="primary" size="lg">Contact Us</Button>
        <Button href="/program" variant="outline" size="lg">View Full Program</Button>
      </div>
    </div>
  </section>

</BaseLayout>
