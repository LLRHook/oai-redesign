---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import FormField from '../components/FormField.astro';
---

<BaseLayout title="Call for Speakers | Optimized AI Conference 2026" description="Apply to speak at the Optimized AI Conference 2026 in Atlanta, March 30-31.">

  <!-- Hero -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute top-20 left-0 w-[300px] h-[300px] opacity-[0.04]"
      style="background: linear-gradient(45deg, #00D4AA, transparent 60%); clip-path: polygon(0% 30%, 70% 0%, 100% 70%, 30% 100%, 0% 100%);"
    ></div>

    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <span
        class="inline-flex items-center px-4 py-1.5 rounded-md text-xs font-display font-600 uppercase tracking-widest border bg-secondary/10 text-secondary border-secondary/20 mb-6"
        style="animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;"
      >
        Share Your Expertise
      </span>
      <h1
        class="font-display text-5xl md:text-6xl font-700 text-text-primary tracking-tight mb-6"
        style="animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;"
      >
        Call for Speakers
      </h1>
      <p
        class="text-lg text-text-secondary font-body max-w-2xl mx-auto mb-10"
        style="animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;"
      >
        We're looking for practitioners, researchers, and leaders who are building real AI systems. Share your experience with our community of 70+ speakers and hundreds of attendees.
      </p>
    </div>
  </section>

  <!-- Topics & Form -->
  <section class="py-20 bg-surface">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Topics -->
        <div class="lg:col-span-2 animate-on-scroll">
          <h2 class="font-display text-2xl font-600 text-text-primary mb-6">Topics We're Looking For</h2>
          <ul class="space-y-4">
            {[
              "Agentic AI Systems & Multi-Agent Architectures",
              "Production ML/AI Deployment & Scaling",
              "LLM Training, Fine-tuning & Inference Optimization",
              "RAG Systems & Retrieval Engineering",
              "AI Security, Governance & Compliance",
              "GPU Computing & Infrastructure",
              "Context Engineering & Memory Systems",
              "AI Strategy & Leadership",
              "Open Source AI Tools & Frameworks",
              "Real-world Case Studies & Lessons Learned",
            ].map((topic) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-secondary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm text-text-secondary font-body">{topic}</span>
              </li>
            ))}
          </ul>

          <div class="mt-10 p-6 rounded-xl bg-surface-elevated border border-surface-border">
            <h3 class="font-display text-lg font-600 text-text-primary mb-3">Conference Details</h3>
            <div class="space-y-2 text-sm text-text-secondary font-body">
              <p><strong class="text-text-primary font-display font-500">Dates:</strong> March 30-31, 2026</p>
              <p><strong class="text-text-primary font-display font-500">Location:</strong> Cobb Galleria Center, Atlanta, GA</p>
              <p><strong class="text-text-primary font-display font-500">Format:</strong> 25-45 minute talks + hands-on workshops</p>
              <p><strong class="text-text-primary font-display font-500">Audience:</strong> AI practitioners, engineers, researchers, and executives</p>
            </div>
          </div>
        </div>

        <!-- Application Form -->
        <div class="lg:col-span-3 animate-on-scroll">
          <div class="rounded-xl bg-surface-elevated border border-surface-border p-8 lg:p-10">
            <h2 class="font-display text-2xl font-600 text-text-primary mb-8">Apply to Speak</h2>
            <form id="speaker-form" class="space-y-6" action="#" method="POST">
              <FormField label="Full Name" type="text" name="name" required={true} />
              <FormField label="Email" type="email" name="email" required={true} />
              <FormField label="Company / Organization" type="text" name="company" required={true} />
              <FormField label="Talk Title" type="text" name="talk_title" required={true} />
              <FormField label="Talk Description" type="textarea" name="description" required={true} />
              <FormField label="LinkedIn Profile URL" type="text" name="linkedin" required={false} />
              <Button variant="secondary" size="lg">
                Submit Application
              </Button>
            </form>
            <div id="speaker-success" class="hidden text-center py-12">
              <div class="w-16 h-16 rounded-full bg-secondary/10 flex items-center justify-center mx-auto mb-6">
                <svg class="w-8 h-8 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="font-display text-2xl font-600 text-text-primary mb-3">Application Received!</h3>
              <p class="text-text-secondary font-body">Thank you for your interest in speaking. We'll review your application and get back to you within 48 hours.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    document.getElementById('speaker-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const form = document.getElementById('speaker-form');
      const success = document.getElementById('speaker-success');
      if (form && success) {
        form.classList.add('hidden');
        success.classList.remove('hidden');
      }
    });
  </script>

</BaseLayout>
