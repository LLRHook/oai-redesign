---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ScheduleRow from '../components/ScheduleRow.astro';
import Badge from '../components/Badge.astro';
import Button from '../components/Button.astro';
import { virtualSchedule, inPersonSchedule } from '../data/schedule';
import { workshops } from '../data/workshops';
---

<BaseLayout title="Program | Optimized AI Conference 2026" description="Conference program: 2 days, 50+ talks, 11 workshops, and keynotes from industry leaders.">

  <!-- Hero -->
  <HeroSection
    title="Program"
    subtitle="Two days of talks, keynotes, panels, and hands-on workshops at the Cobb Galleria Center, Atlanta."
    badge="March 30-31, 2026"
  />

  <!-- In-Person Program Overview -->
  <section class="py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <SectionHeader
        title="In-Person Conference"
        subtitle="Join us at the Cobb Galleria Center for two packed days of AI learning and networking."
        badge="Atlanta, GA"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto animate-on-scroll">
        <!-- Day 1 -->
        <div class="rounded-xl bg-surface-elevated border border-surface-border p-8 transition-all duration-300 hover:border-primary/30 hover:-translate-y-1">
          <Badge variant="primary">Day 1</Badge>
          <h3 class="font-display text-2xl font-600 text-text-primary mt-4 mb-2">{inPersonSchedule.day1.date}</h3>
          <p class="font-display text-lg font-500 text-primary mb-4">{inPersonSchedule.day1.label}</p>
          <p class="text-sm text-text-secondary font-body leading-relaxed mb-6">{inPersonSchedule.day1.description}</p>
          <div class="space-y-3">
            <div class="flex items-center gap-3 text-sm text-text-secondary font-body">
              <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Keynotes from industry leaders</span>
            </div>
            <div class="flex items-center gap-3 text-sm text-text-secondary font-body">
              <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Breakout sessions & panels</span>
            </div>
            <div class="flex items-center gap-3 text-sm text-text-secondary font-body">
              <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Networking opportunities</span>
            </div>
          </div>
        </div>

        <!-- Day 2 -->
        <div class="rounded-xl bg-surface-elevated border border-surface-border p-8 transition-all duration-300 hover:border-secondary/30 hover:-translate-y-1">
          <Badge variant="secondary">Day 2</Badge>
          <h3 class="font-display text-2xl font-600 text-text-primary mt-4 mb-2">{inPersonSchedule.day2.date}</h3>
          <p class="font-display text-lg font-500 text-secondary mb-4">{inPersonSchedule.day2.label}</p>
          <p class="text-sm text-text-secondary font-body leading-relaxed mb-6">{inPersonSchedule.day2.description}</p>
          <div class="space-y-3">
            <div class="flex items-center gap-3 text-sm text-text-secondary font-body">
              <svg class="w-4 h-4 text-secondary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Morning talks & sessions</span>
            </div>
            <div class="flex items-center gap-3 text-sm text-text-secondary font-body">
              <svg class="w-4 h-4 text-secondary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>11 hands-on workshops (1:00 PM)</span>
            </div>
            <div class="flex items-center gap-3 text-sm text-text-secondary font-body">
              <svg class="w-4 h-4 text-secondary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Guided by industry pioneers</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Virtual Event Schedule -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <SectionHeader
        title="Virtual Event Schedule"
        subtitle="October 29, 2025 | 9:00 AM - 3:00 PM PST -- Recordings now available."
        badge="Past Event - Recordings Available"
      />

      <div class="max-w-3xl mx-auto space-y-2 animate-on-scroll">
        {virtualSchedule.map((item) => (
          <ScheduleRow
            time={item.time}
            title={item.title}
            speaker={item.speaker}
            type={item.type}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Workshop Schedule -->
  <section class="py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <SectionHeader
        title="Day 2 Workshop Schedule"
        subtitle="Afternoon sessions starting at 1:00 PM on March 31, 2026."
        badge="11 Workshops"
      />

      <div class="max-w-3xl mx-auto space-y-3 animate-on-scroll">
        {workshops.map((ws) => (
          <a href={`/workshops/${ws.slug}`} class="group block">
            <div class="flex flex-col sm:flex-row items-start gap-4 sm:gap-8 py-5 px-5 rounded-lg border-l-4 border-l-primary bg-surface-elevated/30 transition-all duration-300 hover:bg-surface-elevated group-hover:border-l-secondary">
              <div class="flex-shrink-0 w-36">
                <span class="font-display text-sm font-600 text-text-tertiary">{ws.time}</span>
              </div>
              <div class="flex-1">
                <div class="flex flex-wrap items-center gap-3 mb-1">
                  <h4 class="font-display text-base font-600 text-text-primary group-hover:text-primary transition-colors duration-200">{ws.title}</h4>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-display font-600 uppercase tracking-wider bg-secondary/10 text-secondary border border-secondary/20">
                    {ws.duration}
                  </span>
                </div>
                <p class="text-sm text-text-secondary font-body">{ws.speakerName}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Venue -->
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center animate-on-scroll">
      <h2 class="font-display text-3xl md:text-4xl font-600 text-text-primary mb-4">
        Venue & Hotel
      </h2>
      <p class="text-lg text-text-secondary font-body mb-6">
        Cobb Galleria Center, Atlanta, GA
      </p>
      <p class="text-sm text-text-tertiary font-body mb-8">
        Hotels are available nearby. Visit the registration page for hotel partner information and group rates.
      </p>
      <Button href="/contact" variant="primary" size="lg">Register Now</Button>
    </div>
  </section>

</BaseLayout>
