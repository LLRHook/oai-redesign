---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormField from '../components/FormField.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Sign Up | Optimized AI Conference 2026" description="Sign up to access past talk recordings from the Optimized AI Conference virtual event.">

  <!-- Hero -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute top-20 right-0 w-[300px] h-[300px] opacity-[0.04]"
      style="background: linear-gradient(135deg, #FF6B35, transparent 60%); clip-path: polygon(30% 0%, 100% 0%, 100% 70%, 70% 100%);"
    ></div>

    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <span
        class="inline-flex items-center px-4 py-1.5 rounded-md text-xs font-display font-600 uppercase tracking-widest border bg-secondary/10 text-secondary border-secondary/20 mb-6"
        style="animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;"
      >
        Free Access
      </span>
      <h1
        class="font-display text-5xl md:text-6xl font-700 text-text-primary tracking-tight mb-6"
        style="animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;"
      >
        Get Past Talk Recordings
      </h1>
      <p
        class="text-lg text-text-secondary font-body max-w-2xl mx-auto"
        style="animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;"
      >
        Sign up with your email to get free access to all recorded talks from the October 2025 virtual event, featuring speakers from Google, NVIDIA, AWS, and more.
      </p>
    </div>
  </section>

  <!-- Sign Up Form -->
  <section class="py-20 bg-surface">
    <div class="max-w-xl mx-auto px-6 lg:px-8">
      <div class="rounded-xl bg-surface-elevated border border-surface-border p-8 lg:p-10 animate-on-scroll">
        <h2 class="font-display text-2xl font-600 text-text-primary mb-2">Sign up for recordings</h2>
        <p class="text-sm text-text-secondary font-body mb-8">Enter your email below and we'll send you a link to watch all past talks.</p>

        <form id="signup-form" class="space-y-6" action="#" method="POST">
          <FormField label="Full Name" type="text" name="name" required={true} />
          <FormField label="Email Address" type="email" name="email" required={true} />
          <FormField label="Company / Organization (optional)" type="text" name="company" required={false} />
          <Button variant="secondary" size="lg">
            Get Free Access
          </Button>
        </form>

        <div id="signup-success" class="hidden text-center py-12">
          <div class="w-16 h-16 rounded-full bg-secondary/10 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="font-display text-2xl font-600 text-text-primary mb-3">You're in!</h3>
          <p class="text-text-secondary font-body">Check your email for a link to the recordings. If you don't see it, check your spam folder.</p>
        </div>
      </div>

      <!-- What's Included -->
      <div class="mt-12 animate-on-scroll">
        <h3 class="font-display text-lg font-600 text-text-primary mb-6 text-center">What's included in the recordings</h3>
        <div class="space-y-4">
          {[
            "What's New and What's Next for Generative AI? -- Paige Bailey",
            "Building Enterprise Multi-Agent Communications -- Jake Mannix",
            "A Bold & Responsible Agentic Future -- Pilar Manchon",
            "AI Knowledge Layer for Agents -- Philip Rathle",
            "Self Optimizing Agents for Deep Research -- Jakub Zavrel",
            "Security & Governance: The Achilles Heel of Enterprise Agentic AI -- Raja Iqbal",
            "AI for Coding -- Chip Huyen",
          ].map((talk) => (
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-secondary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="text-sm text-text-secondary font-body">{talk}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script>
    document.getElementById('signup-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const form = document.getElementById('signup-form');
      const success = document.getElementById('signup-success');
      if (form && success) {
        form.classList.add('hidden');
        success.classList.remove('hidden');
      }
    });
  </script>

</BaseLayout>
