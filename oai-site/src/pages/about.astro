---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="About | Optimized AI Conference 2026" description="Learn about the Optimized AI Conference -- a practitioner-focused AI event in Atlanta, March 30-31, 2026.">

  <!-- Hero -->
  <HeroSection
    title="About OAI Conference"
    subtitle="A practitioner-focused AI conference designed for students, professionals, and executives alike. Affordable, hands-on, no fluff."
    badge="March 30-31, 2026 | Atlanta, GA"
  />

  <!-- Mission -->
  <section class="py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <div class="animate-on-scroll">
          <span class="inline-flex items-center px-3 py-1 rounded-md text-xs font-display font-600 uppercase tracking-wider border bg-primary/10 text-primary border-primary/20 mb-4">
            Our Mission
          </span>
          <h2 class="font-display text-4xl md:text-5xl font-600 text-text-primary tracking-tight leading-[1.1] mb-6">
            Shorten your path to production
          </h2>
          <p class="text-lg text-text-secondary font-body leading-relaxed mb-6">
            Building and deploying analytics, machine-learning, and gen AI applications to production is no easy task. The Optimized AI Conference brings together practitioners who are solving real problems -- not just talking about them.
          </p>
          <p class="text-text-secondary font-body leading-relaxed">
            We recruit speakers from top companies like Google, Microsoft, NVIDIA, AWS, Netflix, The Home Depot, Redis, Meta, Walmart, and LinkedIn to share the latest industry best practices. Every talk and workshop is designed to give you skills, strategies, and tools you can use immediately.
          </p>
        </div>

        <div class="animate-on-scroll">
          <div class="grid grid-cols-2 gap-6">
            <div class="rounded-xl bg-surface-elevated border border-surface-border p-6 text-center transition-all duration-300 hover:border-primary/20 hover:-translate-y-1">
              <div class="font-display text-4xl font-700 text-primary mb-2">70+</div>
              <p class="text-sm text-text-secondary font-body">Speakers</p>
            </div>
            <div class="rounded-xl bg-surface-elevated border border-surface-border p-6 text-center transition-all duration-300 hover:border-secondary/20 hover:-translate-y-1">
              <div class="font-display text-4xl font-700 text-secondary mb-2">11</div>
              <p class="text-sm text-text-secondary font-body">Workshops</p>
            </div>
            <div class="rounded-xl bg-surface-elevated border border-surface-border p-6 text-center transition-all duration-300 hover:border-primary/20 hover:-translate-y-1">
              <div class="font-display text-4xl font-700 text-primary mb-2">2</div>
              <p class="text-sm text-text-secondary font-body">Days</p>
            </div>
            <div class="rounded-xl bg-surface-elevated border border-surface-border p-6 text-center transition-all duration-300 hover:border-secondary/20 hover:-translate-y-1">
              <div class="font-display text-4xl font-700 text-secondary mb-2">50+</div>
              <p class="text-sm text-text-secondary font-body">Talks</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What to Expect -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <SectionHeader
        title="What to Expect"
        subtitle="Two packed days of keynotes, panels, breakout sessions, and hands-on workshops at the Cobb Galleria Center."
        badge="Conference Format"
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 animate-on-scroll">
        <div class="rounded-xl bg-surface-elevated border border-surface-border p-6 transition-all duration-300 hover:border-primary/20 hover:-translate-y-1">
          <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-600 text-text-primary mb-2">Day 1: Conference Talks</h3>
          <p class="text-sm text-text-secondary font-body leading-relaxed">
            A full day of keynotes, talks, and panels from industry leaders covering agentic AI, production ML, LLM optimization, and more.
          </p>
        </div>

        <div class="rounded-xl bg-surface-elevated border border-surface-border p-6 transition-all duration-300 hover:border-secondary/20 hover:-translate-y-1">
          <div class="w-12 h-12 rounded-lg bg-secondary/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-600 text-text-primary mb-2">Day 2: Talks + Workshops</h3>
          <p class="text-sm text-text-secondary font-body leading-relaxed">
            Morning talks followed by 11 hands-on afternoon workshops starting at 1:00 PM. Build real projects with expert guidance.
          </p>
        </div>

        <div class="rounded-xl bg-surface-elevated border border-surface-border p-6 transition-all duration-300 hover:border-primary/20 hover:-translate-y-1">
          <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-600 text-text-primary mb-2">Networking</h3>
          <p class="text-sm text-text-secondary font-body leading-relaxed">
            Connect with AI practitioners, engineers, researchers, and executives from companies like Google, NVIDIA, AWS, Meta, and more.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Affordability -->
  <section class="py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <SectionHeader
        title="Affordable for Everyone"
        subtitle="We believe cost should never be a barrier to learning. That's why we offer multiple free and discounted options."
        badge="Pricing Philosophy"
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto animate-on-scroll">
        <div class="rounded-xl bg-surface-elevated border border-surface-border p-6 text-center">
          <div class="font-display text-2xl font-700 text-primary mb-2">Free</div>
          <p class="text-sm text-text-secondary font-body">Decision Makers & Volunteers</p>
        </div>
        <div class="rounded-xl bg-surface-elevated border border-surface-border p-6 text-center">
          <div class="font-display text-2xl font-700 text-secondary mb-2">$100</div>
          <p class="text-sm text-text-secondary font-body">Student Pass</p>
        </div>
        <div class="rounded-xl bg-surface-elevated border border-surface-border p-6 text-center">
          <div class="font-display text-2xl font-700 text-text-primary mb-2">$250-$400</div>
          <p class="text-sm text-text-secondary font-body">Early Bird & Full Conference</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center animate-on-scroll">
      <h2 class="font-display text-3xl md:text-4xl font-600 text-text-primary mb-4">
        Ready to join us?
      </h2>
      <p class="text-text-secondary font-body mb-8">
        March 30-31, 2026 at the Cobb Galleria Center, Atlanta, GA.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/contact" variant="primary" size="lg">Register Now</Button>
        <Button href="/speakers" variant="outline" size="lg">View Speakers</Button>
      </div>
    </div>
  </section>

</BaseLayout>
